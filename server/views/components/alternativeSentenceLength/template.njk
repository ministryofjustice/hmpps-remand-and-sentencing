{% from "govuk/components/error-message/macro.njk" import govukErrorMessage %}

<div class="govuk-form-group {%- if params.errorMessage %} govuk-form-group--error{% endif %}">
    {% if params.errorMessage %}
        {% set errorId = params.id + '-error' %}
        {{ govukErrorMessage({
            id: errorId,
            classes: params.errorMessage.classes,
            attributes: params.errorMessage.attributes,
            html: params.errorMessage.html,
            text: params.errorMessage.text,
            visuallyHiddenText: params.errorMessage.visuallyHiddenText
        }) | trim | indent(2) }}
    {% endif %}
    <label class="govuk-label govuk-visually-hidden" for="{{ params.id }}-value">
        Sentence length value
    </label>
    <input class="govuk-input govuk-input--width-2 govuk-!-margin-right-2 {%- if params.errorMessage %} govuk-input--error{% endif %}"
           id="{{ params.id }}-value"
           name="{{ params.name }}-value"
           value="{{ params.value }}"
           type="text"
           inputmode="numeric">

    <label class="govuk-label govuk-visually-hidden" for="{{ params.id }}-period">
        Sentence length unit
    </label>
    <select class="govuk-select alternative-sentence-length-select {%- if params.errorMessage %} govuk-select--error{% endif %}"
            id="{{ params.id }}-period"
            name="{{ params.name }}-period">
        <option value="years" {% if params.selectedItem === 'years' %} selected {% endif %}>years</option>
        <option value="months" {% if params.selectedItem === 'months' %} selected {% endif %}>months</option>
        <option value="weeks" {% if params.selectedItem === 'weeks' %} selected {% endif %}>weeks</option>
        <option value="days" {% if params.selectedItem === 'days' %} selected {% endif %}>days</option>
    </select>
</div>
