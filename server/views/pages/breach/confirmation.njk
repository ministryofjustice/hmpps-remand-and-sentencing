{% extends "../../partials/prisonerBannerLayout.njk" %}
{% from "govuk/components/panel/macro.njk" import govukPanel %}
{% from "govuk/components/button/macro.njk" import govukButton %}


{% set pageTitle = applicationName + " - Breach successfully saved" %}

{% block subNavigation %}
{% endblock %}

{% block content %}

    {% set titleHtml %}
        <span class="govuk-!-font-size-36">
            Breach hearing successfully saved
        </span>
    {% endset %}

    <div class="govuk-grid-row govuk-!-margin-top-4">
        <div class="govuk-grid-column-two-thirds">
            {{ govukPanel({
                titleHtml: titleHtml,
                classes: "govuk-!-margin-bottom-6"
            }) }}

            <div class="govuk-!-margin-top-6">
                <h2 class="govuk-heading-l">What you can do next</h2>

                <div class="govuk-body govuk-!-margin-top-6">
                    <span>You can go back to {{ prisoner | firstNameSpaceLastName | pluraliseName }}:</span>
                    <ul class="govuk-list govuk-!-margin-top-2">
                        <li>
                            <a class="govuk-link govuk-link--no-visited-state" href="/person/{{ nomsId }}">
                                Court case information
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="govuk-!-margin-top-6">
                    <p class="govuk-body">
                        Or, go to the
                        <a class="govuk-link govuk-link--no-visited-state" href="{{ digitalPrisonServicesUrl }}">
                            DPS homepage
                        </a>.
                    </p>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
