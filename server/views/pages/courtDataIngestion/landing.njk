{% extends "../../partials/prisonerBannerLayout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% set pageTitle = applicationName + " - Warrant received" %}

{% block content %}
    <h1 class="govuk-heading-l">
        Review new documents and add a court case
    </h1>

    <p class="govuk-body">A new remand warrant for <strong>{{appearance.courtCaseReference}}</strong> has been added from Common Platform.</p>
    <p class="govuk-body">Some information has been added for you.</p>
    <h3 class="govuk-heading-s">The following documents have been added:</h3>

    <div class="govuk-!-padding-bottom-3">
    {% for document in appearance.documents %}
        <a href="/api/document/{{document.documentUUID}}/download">{{document.fileName}}</a>
        <p class="govuk-body">{{document.documentTypeDescription}}</p>
        <hr />
    {% endfor %}
    </div>

    <h3 class="govuk-heading-s">What you need to do</h3>
    <p class="govuk-body">Review the documents then continue to enter information exactly as it is written on the warrant.</p>


    <div class="govuk-button-group">
        {{ govukButton({
        text: "Continue",
        href: "/person/" + nomsId + "/review-new-documents/" + hmctsHearingId + "/start",
        attributes: { "data-qa": "hmcts-court-data-continue" }
        }) }}
        {{ govukButton({
        text: "Cancel",
        classes: "govuk-button--secondary",
        attributes: { 'data-qa': 'cancel-button' },
        href: "/person/" + nomsId
        }) }}
    </div>

{% endblock %}
