{% extends "../partials/prisonerBannerLayout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "hmpps/components/court-cases-release-dates/offence-card/macro.njk" import offenceCard %}
{% from "hmpps/components/court-cases-release-dates/things-to-do/macro.njk" import thingsToDo %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{%- from "moj/components/date-picker/macro.njk" import mojDatePicker -%}
{% from "govuk/components/fieldset/macro.njk" import govukFieldset %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}


{% set pageTitle = applicationName + " - Home" %}

{% block content %}
{% if successMessage %}

{% set html %}
  <h3 class="govuk-notification-banner__heading" data-qa="notification-banner-heading">
    This court case has been deleted.
  </h3>
  <p class="govuk-body" data-qa="notification-banner-content">{{successMessage}}</p>
{% endset %}

  {{ govukNotificationBanner({
    html: html,
    type: "success"
  }) }}
{% endif %}

    <h1 class="govuk-heading-xl">Court cases</h1>
    <div class="govuk-grid-row">

        <div class="govuk-grid-column-two-thirds">
            {% if courtCaseDetailModels | length %}
            {{ thingsToDo(serviceDefinitions, 'courtCases') }}
            {% endif %}
            {% if prisonerCourtCaseTotal %}
            {% if filterErrors | length %}
                <div class="govuk-grid-row govuk-!-margin-top-4">
                    {{ govukErrorSummary({
                        titleText: "There is a problem",
                        errorList: filterErrors
                    }) }}
                </div>
            {% endif %}
            <div class="govuk-grid-row">
                <div class="govuk-grid-column-full govuk-!-margin-bottom-3">
                        <details class="govuk-details filter filter-box govuk-!-margin-bottom-2"{% if filterErrors | length %} open {% endif %}>
                            <summary class="govuk-details__summary" data-qa="filterSortSummary">
                                <span class="govuk-details__summary-text">
                                    Filter previous periods of custody
                                </span>
                                <div class="gouk-body govuk-!-font-weight-bold results">Showing {% if paginationResults.count%}<strong>{{ paginationResults.from }}</strong> to <strong>{{ paginationResults.to }}</strong>{% else %}<strong>0</strong>{% endif %} of <strong>{{ prisonerCourtCaseTotal }}</strong> court cases</div>
                            </summary>
                            <div class="govuk-details__text">
                                <form>
                                    {{
                                        govukCheckboxes({
                                            name: 'includeCasesFromPreviousPeriodsOfCustody',
                                            classes: "govuk-checkboxes--small",
                                            fieldset: {
                                                legend: {
                                                    text: "Previous cases",
                                                    classes: "govuk-fieldset__legend--s"
                                                }
                                            },
                                            items: [{
                                                value: 'true',
                                                text: 'Include cases from previous periods of custody (' ~ bookingCourtCasePreviousPeriodsCount ~ ')',
                                                checked: includeCasesFromPreviousPeriodsOfCustody === 'true',
                                                disabled: disableIncludeCasesFromPreviousPeriodsOfCustody
                                            }]
                                        })
                                    }}

                                    {{ govukRadios({
                                      name: "sortBy",
                                      classes: "govuk-radios--small",
                                      fieldset: {
                                        legend: {
                                          text: "Sort by",
                                          classes: "govuk-fieldset__legend--s"
                                        }
                                      },
                                      items: [
                                        {
                                          value: "APPEARANCE_DATE_DESC",
                                          text: "Court appearance (most recent)",
                                          checked: sortBy === 'APPEARANCE_DATE_DESC'
                                        },
                                        {
                                          value: "APPEARANCE_DATE_ASC",
                                          text: "Court appearance (earliest)",
                                          checked: sortBy === 'APPEARANCE_DATE_ASC'
                                        }
                                      ]
                                    }) }}

                                    {{ govukButton({
                                        text: "Apply",
                                        classes: 'govuk-!-margin-bottom-1',
                                        attributes: {
                                            'data-qa': 'applyButton'
                                        }
                                    }) }}

                                </form>
                            </div>
                        </details>
                </div>
            </div>
            {% endif %}
            <div class="govuk-grid-row">
                <div class="govuk-grid-column-full" data-qa="court-cases">
                {% for courtCaseDetails in courtCaseDetailModels %}
                        {% set courtCaseSummary %}

                            {% set nextAppearanceHtml %}
                            <ul class="govuk-list">
                                {% for nextAppearanceValue in courtCaseDetails.nextAppearance %}
                                    <li>
                                        {{ nextAppearanceValue }}
                                    </li>
                                {% endfor %}
                            </ul>
                            {% endset %}

                            {% set courtCaseSummaryRows = [
                                    {
                                        key: { text: "Case references"},
                                        value: { text: courtCaseDetails.caseReferences if courtCaseDetails.caseReferences else 'Not entered' }
                                    },
                                    {
                                        key: { text: "First day in custody"},
                                        value: { text: courtCaseDetails.firstDayInCustody + ( ' (' + courtCaseDetails.firstDayInCustodyWarrantType | capitalize + ')' if courtCaseDetails.firstDayInCustodyWarrantType === 'SENTENCING' else '') }
                                    },
                                    {
                                        key: { text: "Overall case outcome"},
                                        value: { text: courtCaseDetails.overallCaseOutcome }
                                    }
                            ] %}
                            {% if courtCaseDetails.warrantType === 'SENTENCING' %}
                                {% set courtCaseSummaryRows = (courtCaseSummaryRows.concat([{
                                        key: { text: "Overall sentence length"},
                                        value: { text: courtCaseDetails.overallSentenceLength | formatLengths if courtCaseDetails.overallSentenceLength else 'Not entered' }
                                    }
                                    ]))%}
                            {% endif %}
                            {% if courtCaseDetails.warrantType === 'BREACH_OF_SUPERVISION_REQUIREMENTS' %}
                                {% set courtCaseSummaryRows = (courtCaseSummaryRows.concat([{
                                        key: { text: "Breach of supervision requirements"},
                                        value: { text: courtCaseDetails.overallBreachOfSupervisionLength | formatLengths if courtCaseDetails.overallBreachOfSupervisionLength else 'Not entered' }
                                    }
                                    ]))%}
                            {% endif %}
                            {% if courtCaseDetails.warrantType === 'NON_SENTENCING' %}
                              {% set courtCaseSummaryRows = (courtCaseSummaryRows.concat(
                                      {
                                          key: { text: "Next appearance"},
                                          value: { html: nextAppearanceHtml }
                                      }
                              ))%}
                            {% endif %}
                            {% if courtCaseDetails.hasARecall and not user.hasRecallsAccess %}

                                {{ govukInsetText({
                                    text: "The court case was part of a recall. To make any changes to the recall, update the details in NOMIS then reload this page.",
                                    classes: "govuk-!-margin-top-2",
                                    attributes: {
                                        "data-qa": "recallInset-" + courtCaseDetails.courtCaseUuid
                                    }
                                }) }}
                            {% endif %}

                            {% if courtCaseDetails.mergedToCase %}
                                {{ govukInsetText({
                                    text: courtCaseDetails.mergedToCase | formatMergedToCase(courtMap),
                                    classes: "govuk-!-margin-top-2",
                                    attributes: {
                                        "data-qa": "mergedToCaseInset-" + courtCaseDetails.courtCaseUuid
                                    }
                                }) }}
                            {% endif %}

                            {% if courtCaseDetails.mergedFromCases and courtCaseDetails.mergedFromCases.length %}
                                {% set mergedFromCasesHtml = '' %}

                                {% for mergeFromCase in courtCaseDetails.mergedFromCases%}
                                    {% set mergedFromCasesHtml = mergedFromCasesHtml + ('<br>' if not loop.first else '') + mergeFromCase | formatOverallMergedFromCase(courtMap) %}
                                {% endfor %}
                                {{ govukInsetText({
                                    html: mergedFromCasesHtml,
                                    classes: "govuk-!-margin-top-2",
                                    attributes: {
                                        "data-qa": "mergedCaseInset-" + courtCaseDetails.courtCaseUuid
                                    }
                                }) }}
                            {% endif %}

                            {{
                                govukSummaryList({
                                    rows: courtCaseSummaryRows,
                                    attributes: {
                                        "data-qa": "courtCaseSummary-" + courtCaseDetails.courtCaseUuid
                                    }
                                })
                            }}

                            <hr class="govuk-section-break govuk-section-break--visible">
                            <div class="govuk-grid-row">
                                    <div class="govuk-grid-column-one-half">
                                        <h2 class="govuk-heading-m govuk-!-margin-top-6 govuk-!-margin-bottom-2">Latest hearing</h2>
                                    </div>
                                </div>
                                <div class="govuk-grid-row govuk-!-padding-bottom-2 govuk-!-margin-top-2">
                                    <div class="govuk-grid-column-one-third">
                                        <h3 class="govuk-heading-s govuk-!-margin-bottom-1">Case reference</h3>
                                        <p class="govuk-body govuk-!-margin-bottom-2" data-qa="latestAppearanceCourtCaseReference-{{courtCaseDetails.courtCaseUuid}}">{{ courtCaseDetails.latestAppearance.caseReference if courtCaseDetails.latestAppearance.caseReference else 'Not entered'}}</p>
                                        <h3 class="govuk-heading-s govuk-!-margin-bottom-1">Hearing date</h3>
                                        <p class="govuk-body govuk-!-margin-bottom-2" data-qa="latestAppearanceWarrantDate-{{courtCaseDetails.courtCaseUuid}}">{{ courtCaseDetails.latestAppearance.warrantDate | formatDate }}</p>
                                        {% if courtCaseDetails.latestAppearance.warrantType === 'SENTENCING' %}
                                            <h3 class="govuk-heading-s govuk-!-margin-bottom-1">Conviction date</h3>
                                            <p class="govuk-body govuk-!-margin-bottom-2" data-qa="latestAppearanceConvictionDate-{{courtCaseDetails.courtCaseUuid}}">{{ courtCaseDetails.latestAppearance.convictionDate | formatDate if courtCaseDetails.latestAppearance.convictionDate else 'Not entered' }}</p>
                                        {% endif %}
                                        {% if courtCaseDetails.latestAppearance.warrantType === 'APPEAL' %}
                                            <h3 class="govuk-heading-s govuk-!-margin-bottom-1">Criminal Appeal Office case reference</h3>
                                            <p class="govuk-body govuk-!-margin-bottom-2" data-qa="latestAppearanceCriminalAppealReference-{{courtCaseDetails.courtCaseUuid}}">{{ courtCaseDetails.latestAppearance.criminalAppealOfficeReference if courtCaseDetails.latestAppearance.criminalAppealOfficeReference else 'Not entered' }}</p>
                                        {% endif %}
                                    </div>
                                    <div class="govuk-grid-column-two-thirds">
                                        <h3 class="govuk-heading-s govuk-!-margin-bottom-1">Location</h3>
                                        <p class="govuk-body govuk-!-margin-bottom-2" data-qa="latestAppearanceLocation-{{courtCaseDetails.courtCaseUuid}}">{{ courtMap[courtCaseDetails.latestAppearance.courtCode] }}</p>
                                        <h3 class="govuk-heading-s govuk-!-margin-bottom-1">Outcome</h3>
                                        <p class="govuk-body govuk-!-margin-bottom-2" data-qa="latestAppearanceOutcome-{{courtCaseDetails.courtCaseUuid}}"> {{ courtCaseDetails.latestAppearance.outcome if courtCaseDetails.latestAppearance.outcome else 'Not entered' }}</p>
                                    </div>
                                    <div class="govuk-grid-column-full govuk-!-margin-top-2">
                                        {% set offenceDetailsHtml %}
                                            {% for offence in courtCaseDetails.offences %}
                                                {{
                                                    offenceCard({
                                                        offenceCode: offence.offenceCode,
                                                        offenceName: offenceMap[offence.offenceCode],
                                                        offenceStartDate: offence.offenceStartDate | formatDate if offence.offenceStartDate else 'Not entered',
                                                        offenceEndDate: offence.offenceEndDate | formatDate,
                                                        outcome: offenceOutcomeMap[offence.outcomeUuid] | outcomeValueOrLegacy(offence.legacyData),
                                                        countNumber: offence.sentence.countNumber if offence.sentence,
                                                        lineNumber: offence.sentence.legacyData.nomisLineReference if offence.sentence and offence.sentence.legacyData,
                                                        convictionDate: (offence.sentence.convictionDate | formatDate) if offence.sentence,
                                                        aggravatingFactors: offence | getAggravatingFactors,
                                                        isSentenced: offence.sentence,
                                                        periodLengths: offence.sentence.periodLengths if offence.sentence,
                                                        sentenceServeType: offence.sentence.sentenceServeType if offence.sentence,
                                                        consecutiveTo: (consecutiveToSentenceDetailsMap[offence.sentence.consecutiveToSentenceUuid] | checkConsecutiveToSameCase(courtCaseDetails.offences, offence.sentence.consecutiveToSentenceUuid))  if offence.sentence,
                                                        sentenceType: (courtCaseDetails.sentenceTypeMap[offence.sentence.sentenceTypeId] | sentenceTypeValueOrLegacy(offence.sentence.legacyData))  if offence.sentence,
                                                        fineAmount: offence.sentence.fineAmount  if offence.sentence,
                                                        detailsClasses: 'govuk-!-padding-4',
                                                        mergedFromCase: offence.mergedFromCase,
                                                        courtDetails: courtMap
                                                    })
                                                }}
                                            {% endfor %}
                                        {% endset %}

                                        {{ govukDetails({
                                            summaryText: "offences (" + (courtCaseDetails.showingChargeTotal + " of " if courtCaseDetails.showingChargeTotal else "") + courtCaseDetails.chargeTotal + ")",
                                            html: offenceDetailsHtml,
                                            classes: "filter show-toggle govuk-!-margin-bottom-0",
                                                attributes: {
                                                    "data-qa": "courtCaseDetailsComponent-" + courtCaseDetails.courtCaseUuid
                                                }
                                            })
                                        }}
                                    </div>
                            </div>
                            <hr class="govuk-section-break govuk-!-margin-top-4 govuk-section-break--visible">
                            <p class="govuk-body govuk-!-margin-top-6 govuk-!-margin-bottom-2">
                                <a class="govuk-link--no-visited-state govuk-!-font-weight-bold" href="/person/{{nomsId}}/view-court-case/{{courtCaseDetails.courtCaseUuid}}/details">
                                    {% if courtCaseDetails.allAppearancesHaveRecall %}
                                        View all hearings for this court case ({{ courtCaseDetails.appearanceTotal }})
                                    {% else %}
                                        View and edit all hearings for this court case ({{ courtCaseDetails.appearanceTotal }})
                                    {% endif %}

                                </a>
                            </p>

                        {% endset %}

                        {% set actions = [] %}

                        {% if courtCaseDetails.overallCaseStatus == "INACTIVE" or courtCaseDetails.overallCaseStatus == "MERGED" %}
                        {% set _ = actions.push({
                            href: null,
                            html: govukTag({ text: "Inactive" }),
                            visuallyHiddenText: "Inactive"
                        }) %}
                        {% endif %}

                        {% if courtCaseDetails.hasARecall %}
                        {% set _ = actions.push({
                            href: null,
                            html: govukTag({ text: "Recalled", classes: "govuk-tag--purple" }),
                            visuallyHiddenText: "Recalled"
                        }) %}
                        {% endif %}
                        {% if courtCaseDetails.canBreach %}
                            {% set _ = actions.push({
                                href: "/person/" + nomsId + "/edit-court-case/" + courtCaseDetails.courtCaseUuid + "/add-court-appearance/" + courtCaseDetails.newAppearanceUuid + "/breach/new-journey",
                                text: "Add breach",
                                visuallyHiddenText: "Add breach",
                                attributes: {
                                        'data-qa': 'add-breach-link-' + courtCaseDetails.courtCaseUuid
                                    }
                            }) %}
                        {% endif %}
                        {% if courtCaseDetails.canAppeal %}
                            {% set _ = actions.push({
                                href: "/person/" + nomsId + "/edit-court-case/" + courtCaseDetails.courtCaseUuid + "/add-court-appearance/" + courtCaseDetails.newAppearanceUuid + "/appeals/new-journey",
                                text: "Add appeal",
                                visuallyHiddenText: "Add appeal",
                                attributes: {
                                'data-qa': 'add-appeals-link-' + courtCaseDetails.courtCaseUuid
                                }
                            }) %}
                        {% endif %}
                        {% if courtCaseDetails.canAddHearing %}
                            {% set _ = actions.push({
                                href: "/person/" + nomsId + "/edit-court-case/" + courtCaseDetails.courtCaseUuid + "/add-court-appearance/" + courtCaseDetails.newAppearanceUuid + "/new-journey",
                                text: "Add hearing",
                                visuallyHiddenText: "Add hearing",
                                attributes: {
                                'data-qa': 'add-appearance-link-' + courtCaseDetails.courtCaseUuid
                                }
                            }) %}
                        {% endif %}
                        {{
                            govukSummaryList({
                                card: {
                                    title: {
                                        text: courtCaseDetails.title
                                    },
                                    actions: {
                                        items: actions
                                    },
                                    attributes: {
                                        "data-qa": "courtCaseCard-" + courtCaseDetails.courtCaseUuid
                                    }
                                },
                                rows: [
                                {
                                    key: { text: "", classes: 'govuk-!-display-none' },
                                    value: { html: courtCaseSummary }
                                }]
                            })
                        }}
                {% else %}
                    {% if bookingCourtCaseCount and bookingDetails and bookingDetails.activeFlag and bookingCourtCaseCount.otherBookingCount > 0 %}
                        <p class="govuk-body">There are no court cases recorded for this period of custody for {{ prisoner | firstNameSpaceLastName }}.</p>
                        <p class="govuk-body">You can use the filters to show court cases from previous periods of custody.</p>
                    {% else %}
                        <p class="govuk-body">There are no court cases recorded for {{ prisoner | firstNameSpaceLastName }}.</p>
                    {% endif %}
                    {{ thingsToDo(serviceDefinitions, 'courtCases') }}
                    <p class="govuk-body">
                        <a class="govuk-link--no-visited-state" href="/person/{{nomsId}}/add-court-case/{{newCourtCaseId}}/add-court-appearance/{{ appearanceUuid }}/new-journey">Add a court case now</a>
                    </p>
                {% endfor %}
                </div>
            </div>

            {% if pagination %}
                {{ govukPagination(pagination) }}
            {% endif %}

        </div>
            <div class="govuk-grid-column-one-third">

                <div class="actions-list">
                    <ul class="govuk-list actions-list-list">
                        <span class="govuk-heading-m actions-list-header">Actions</span>
                        <li><a href="/person/{{nomsId}}/add-court-case/{{newCourtCaseId}}/add-court-appearance/{{ appearanceUuid }}/new-journey" class="govuk-link govuk-link--no-visited-state">Add a new court case</a></li>
                    </ul>
                </div>
            </div>
    </div>

{% endblock %}
